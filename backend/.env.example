# 复制为 .env 并按需修改

# Anthropic API 密钥（不配置时 Agent 功能自动降级为离线模式）
ANTHROPIC_API_KEY=

# 使用的 Claude 模型
ANTHROPIC_MODEL=claude-opus-4-8

# JWT 签名密钥（生产环境必须改为强随机值，例如 `openssl rand -hex 32` 的输出）
JWT_SECRET=dev-secret-change-me

# Token 有效期（分钟），默认 7 天
JWT_EXPIRE_MINUTES=10080

# 上传文件大小上限（MB）
MAX_UPLOAD_MB=50

# 允许跨域的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
