# 复制为 .env 并按需修改

# ============ 大模型配置（不配置 Key 时 Agent 功能自动降级为离线模式）============

# 协议类型：anthropic 或 openai（OpenAI 兼容协议，可接 DeepSeek/通义/Kimi/中转站等）
LLM_PROVIDER=anthropic

# API 密钥（也兼容 ANTHROPIC_API_KEY / OPENAI_API_KEY 变量名）
# ⚠️ 真实密钥只能写在 .env（已被 .gitignore 忽略），不要写进本模板文件
LLM_API_KEY=

# 自定义接口地址（选填，留空使用官方地址）
# 例：DeepSeek 的 OpenAI 兼容端点 https://api.deepseek.com/v1、
#     DeepSeek 的 Anthropic 兼容端点 https://api.deepseek.com/anthropic、
#     one-api 中转 http://your-host/v1
LLM_BASE_URL=

# 模型名（选填；anthropic 默认 claude-opus-4-8，openai 默认 gpt-4o-mini）
# 例：deepseek-chat / qwen-plus / moonshot-v1-8k
LLM_MODEL=

# ---- 配置示例 1：Anthropic 官方 ----
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-xxxx
# LLM_MODEL=claude-opus-4-8

# ---- 配置示例 2：DeepSeek（OpenAI 兼容）----
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ============ 向量检索（可选）============

# Embedding 走 OpenAI 兼容 /embeddings 接口（Anthropic 协议无嵌入端点）
# 不配置时资料检索自动使用关键词模式，功能不受影响
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# ---- 示例 1：SiliconFlow（国内可用，有免费额度）----
# EMBEDDING_API_KEY=sk-xxxx
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3

# ---- 示例 2：OpenAI 官方 ----
# EMBEDDING_API_KEY=sk-xxxx
# EMBEDDING_MODEL=text-embedding-3-small

# ============ 服务配置 ============

# JWT 签名密钥（生产环境必须改为强随机值，例如 `openssl rand -hex 32` 的输出）
JWT_SECRET=dev-secret-change-me

# Token 有效期（分钟），默认 7 天
JWT_EXPIRE_MINUTES=10080

# 上传文件大小上限（MB）
MAX_UPLOAD_MB=50

# 允许跨域的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
